# Idea Dump — environment variable template
# Copy this file to `.env.local` and fill in real values.
# Server-only secrets must NOT be prefixed NEXT_PUBLIC_.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (S3-compatible object storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Transcription ---
DEEPGRAM_API_KEY=

# --- AI processing ---
ANTHROPIC_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
# Verified sending identity, e.g. `Dumpty <hello@theruff.agency>`.
FEEDBACK_FROM_EMAIL=
# Primary destination for operator notifications, e.g. hello@theruff.agency.
FEEDBACK_TO_EMAIL=
# Optional CC on all operator notifications (feedback + signup).
NOTIFY_CC_EMAIL=
# New-signup alerts. TO falls back to FEEDBACK_TO_EMAIL if unset.
SIGNUP_NOTIFY_TO_EMAIL=
# Shared secret for the Supabase new-user webhook (generate: openssl rand -hex 32).
SIGNUP_WEBHOOK_SECRET=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin dashboard (/humpty) ---
# Comma-separated emails allowed to reach the admin dashboard.
ADMIN_EMAILS=

# --- Web Push (VAPID) — generate: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@theruff.agency
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
